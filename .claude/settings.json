{
  "cleanupPeriodDays": 14,
  "permissions": {
    "allow": [
      "Bash(docker run:*)",
      "Bash(docker compose build:*)",
      "Bash(docker compose run:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose exec:*)",
      "Bash(npx *)",
      "Bash(npm run:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git commit -m ':*)",
      "Bash(git push*)",
      "Bash(gh pr create *)",
      "Bash(gh pr comment *)",
      "Bash(gh api *)",
      "Bash(gh get-comments:*)",
      "WebFetch(domain:dev.classmethod.jp)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *main*)",
      "Bash(git push --force *master*)",
      "Bash(git push -f *main*)",
      "Bash(git push -f *master*)",
      "Bash(git push origin main)",
      "Bash(git push origin master)",
      "Bash(git push -u origin main)",
      "Bash(git push -u origin master)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(chmod 777 *)",
      "Read(./.env)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git add*)",
        "hooks": [{
          "type": "command",
          "command": "git diff --cached --name-only | grep -E '^\\.env' && echo '🚨 .env をステージしようとしています！' && exit 1 || exit 0"
        }]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/.claude/bin/claude-notify.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/.claude/bin/claude-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/dotfiles/.claude/bin/statusline.sh"
  },
  "language": "japanese",
  "effortLevel": "medium",
  "autoUpdatesChannel": "stable",
  "showTurnDuration": true
}
